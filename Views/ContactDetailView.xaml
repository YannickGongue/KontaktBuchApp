<UserControl x:Class="KontaktBuchApp.Views.ContactDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:KontaktBuchApp.Views" xmlns:Controls="clr-namespace:KontaktBuchApp.Themes"
				 mc:Ignorable="d" 
             Height="661" 
				 Width="1145">
	<Grid>
		<Label Content="ContactId" 
            FontSize="24" 
            FontWeight="Bold" 
            HorizontalAlignment="Left" 
            Margin="0,10,0,592"/>

		<TextBox Text="{Binding ContactId}" 
            FontSize="24" 
            HorizontalAlignment="Left" 
            Margin="313,10,0,592" 
            Width="642"/>

		<DataGrid ItemsSource="{Binding Contacts}"
            AutoGenerateColumns="False"
            Margin="10,74,10,80">
			<DataGrid.Columns>
				<DataGridTextColumn Header="Email"
                    Binding="{Binding Email}" />
				<DataGridTextColumn Header="Phone"
                            Binding="{Binding Phone}" />
				<DataGridTextColumn Header="Website"
                            Binding="{Binding Website}" />
				<DataGridTextColumn Header="Fax"
                    Binding="{Binding Fax}" />
				<DataGridTextColumn Header="Mobile" 
					    Binding="{Binding Mobile}" />
			</DataGrid.Columns>
		</DataGrid>

		<Controls:IconButton 
x:Name="btnEdit" 
   Content="EditContact" 
   Command="{Binding EditCommand }"
      CornerRadius="8"
      Width="205"
      Height="63"
      BorderBrush="Gray"
      BorderThickness="2"
      PathData="{StaticResource Edit}"
      Background="RoyalBlue"
      Foreground="White"
			IconColor="Black"
      FontSize="20"
      VerticalAlignment="Bottom"
      HorizontalAlignment="Right"
      Margin="0,0,20,10" 
      Cursor="Hand" 
     Text="Edit Contact" RenderTransformOrigin="0.429,0.766"/>

		<Controls:IconButton 
x:Name="btnDelete" 
   Content="DeleteContact" 
   Command="{Binding DeleteCommand }"
      CornerRadius="8"
      Width="205"
      Height="56"
      BorderBrush="Gray"
      BorderThickness="2"
      PathData="{StaticResource Cancel-Icon}"
      Background="RoyalBlue"
      Foreground="White"
			IconColor="Red"
      FontSize="20"
      VerticalAlignment="Bottom"
      HorizontalAlignment="Left"
      Margin="10,0,0,10" 
      Cursor="Hand" 
     Text="Delete Contact"/>
	</Grid>
</UserControl>
