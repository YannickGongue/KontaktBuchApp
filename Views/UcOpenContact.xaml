<Window x:Class="KontaktBuchApp.Views.UcOpenContact"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:KontaktBuchApp.Views" 
				 xmlns:Controls="clr-namespace:KontaktBuchApp.Themes" 
             Height="350"
				 Width="500">
	<Window.Resources>
		<Style TargetType="Label">
			<Setter Property="Width" Value="150"/>
			<Setter Property="Height" Value="30"/>
			<Setter Property="FontSize" Value="16"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Foreground" Value="Black"/>
		</Style>
		<Style TargetType="TextBox">
			<Setter Property="Width" Value="250"/>
			<Setter Property="Height" Value="35"/>
			<Setter Property="FontSize" Value="14"/>
		</Style>
	</Window.Resources>
	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="150"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>
		<Label Content="ContactId" Grid.Row="0" Grid.Column="0"/>
		<TextBox Text="{Binding ContactId}" Grid.Row="0" Grid.Column="1"
					IsEnabled="False"/>
		
		<Label Content="Mobile" Grid.Row="1" Grid.Column="0"/>
		<TextBox Text="{Binding Mobile}" Grid.Row="1" Grid.Column="1"/>

		<Label Content="Phone" Grid.Row="2" Grid.Column="0"/>
		<TextBox Text="{Binding Phone}" Grid.Row="2" Grid.Column="1"
					IsEnabled="False"/>

		<Label Content="Website" Grid.Row="3" Grid.Column="0"/>
		<TextBox Text="{Binding Website}" Grid.Row="3" Grid.Column="1"
					IsEnabled="False"/>

		<Label Content="Fax" Grid.Row="4" Grid.Column="0"/>
		<TextBox Text="{Binding Fax}" Grid.Row="4" Grid.Column="1"
					IsEnabled="False"/>

		<Label Content="Email" Grid.Row="5" Grid.Column="0"/>
		<TextBox Text="{Binding Email}" Grid.Row="5" Grid.Column="1"
					IsEnabled="False"/>

		<Controls:IconButton
        Grid.Row="6"
        Grid.ColumnSpan="2"
        HorizontalAlignment="Right"
        Width="160"
        Height="60"
        Command="{Binding SaveCommand}"
        Text="Save Contact"
			Background="RoyalBlue"
			Foreground="AliceBlue"
			IconColor="Red"
			BorderBrush="Gray"
        BorderThickness="2"
		  Margin="10,10,0,10" 
         FontSize="18"
		  CornerRadius="8"
		  PathData="{StaticResource Reload}"/>
	</Grid>
</Window>
