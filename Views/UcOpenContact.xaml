<Window x:Class="KontaktBuchApp.Views.UcOpenContact"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:KontaktBuchApp.Views" 
				 xmlns:Controls="clr-namespace:KontaktBuchApp.Themes" 
             Height="450"
				 Width="501">
	<Grid >

		<Label Content="Mobile"
				 Width="100"
				 HorizontalAlignment="Left"
				 Margin="0,18,0,385"/>
		<TextBox Text="{Binding Mobile}"
					 Margin="171,18,43,385" />
		<Label Content="Phone"
				 Width="100"
				 HorizontalAlignment="Left"		
				 Margin="0,78,0,331"/>
		<TextBox Text="{Binding Phone}"
			 Margin="171,78,43,331"/>
		<Label Content="Website" 
				 Width="100"
				 HorizontalAlignment="Left"		
				 Margin="0,134,0,268"/>
		<TextBox Text="{Binding Website}"
			 Margin="171,134,43,268"/>
		<Label Content="Fax" 
				 Width="100"
				 HorizontalAlignment="Left"		
				 Margin="0,197,0,208" />
		<TextBox Text="{Binding Fax}"
			 Margin="171,197,43,208"/>
		<Label Content="Email" 
		 Width="100"
		 HorizontalAlignment="Left"		
		 Margin="0,257,0,148" />
		<TextBox Text="{Binding Email}"
	 Margin="171,257,43,148"/>
		
		<Controls:IconButton 
       x:Name="btnSave" 
   Content="SaveContact" 
   Command="{Binding SaveCommand }"
      CornerRadius="8"
      Width="180"
      Height="69"
      BorderBrush="Gray"
      BorderThickness="2"
      PathData="{StaticResource Reload}"
      Background="RoyalBlue"
      Foreground="White"
			IconColor="Red"
      FontSize="20"
      VerticalAlignment="Top"
      HorizontalAlignment="Right"
      Margin="0,371,30,0" 
      Cursor="Hand" 
     Text="Save Contact"/>
	</Grid>
</Window>
