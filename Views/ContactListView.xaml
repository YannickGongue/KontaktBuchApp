<Window x:Class="KontaktBuchApp.Views.ContactListView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		  xmlns:Controls="clr-namespace:KontaktBuchApp.Themes"
        mc:Ignorable="d"
        Title="KontaktList" 
		  Height="550" 
		  Width="600">
	<Grid>
		<TextBox x:Name="txtSearch" 
            Text="{Binding SearchText}"
            Width="358"
            Height="40"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="50,15,0,0"/>

		<Controls:IconButton 
			x:Name="btnSearch" 
			Content="Search" 
			Command="{Binding SearchCommand }"
            CornerRadius="8"
            Width="155"
            Height="40"
            BorderBrush="Gray"
            BorderThickness="2"
            PathData="{StaticResource Reload}"
            Background="RoyalBlue"
            Foreground="White"
            FontSize="20"
            VerticalAlignment="Top"
            HorizontalAlignment="Right"
            Margin="289,15,20,0" 
            Cursor="Hand" 
			  Text="Search"/>

		<DataGrid ItemsSource="{Binding Contacts}"
          AutoGenerateColumns="False"
			 Margin="10,74,10,80">

			<DataGrid.Columns>
				<DataGridTextColumn Header="ContactId"
                Binding="{Binding ContactId}" />
				<DataGridTextColumn Header="Vorname"
                            Binding="{Binding FirstName}" />

				<DataGridTextColumn Header="Nachname"
                            Binding="{Binding LastName}" />

				<DataGridTextColumn Header="Bild"
                Binding="{Binding ImagePath}" />

				<DataGridComboBoxColumn Header="Address"
    SelectedItemBinding="{Binding Address}"
    DisplayMemberPath="Name"
    SelectedValuePath="CategoryId"
    ItemsSource="{Binding Addresses}" />

				<DataGridComboBoxColumn Header="Contacts"
                SelectedItemBinding="{Binding ContactTypes}"
                DisplayMemberPath="Name"
                SelectedValuePath="CategoryId"
                ItemsSource="{Binding Categories}" />
				
				
			</DataGrid.Columns>
		</DataGrid>

		<Controls:IconButton 
	x:Name="btnOpen" 
	Content="OpenContact" 
	Command="{Binding OpenCommand }"
      CornerRadius="8"
      Width="205"
      Height="40"
      BorderBrush="Gray"
      BorderThickness="2"
      PathData="{StaticResource Maintenance}"
      Background="RoyalBlue"
      Foreground="White"
			IconColor="Black"
      FontSize="20"
      VerticalAlignment="Bottom"
      HorizontalAlignment="Left"
      Margin="24,0,0,26" 
      Cursor="Hand" 
	  Text="Open Contact"/>


		<Controls:IconButton 
	x:Name="btnAdd" 
	Content="AddContact" 
	Command="{Binding AddCommand }"
      CornerRadius="8"
      Width="205"
      Height="40"
      BorderBrush="Gray"
      BorderThickness="2"
      PathData="{StaticResource file-info}"
      Background="RoyalBlue"
      Foreground="White"
      FontSize="20"
      VerticalAlignment="Bottom"
      HorizontalAlignment="Right"
      Margin="0,0,20,26" 
      Cursor="Hand" 
	  Text="Add New Contact"/>
	</Grid>
</Window>
